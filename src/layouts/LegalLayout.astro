---
/**
 * Reader-optimized layout for long-form legal / policy documents.
 * Content is fully data-driven: pass a `doc` object resolved from `i18n.legal`.
 * Wraps BaseLayout so the global header, footer, theme, and SEO stay consistent.
 */
import BaseLayout from "./BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { getLangFromUrl, useTranslations, localizePath } from "../utils/i18n";

interface LegalSection {
  heading: string;
  paragraphs: string[];
}
interface LegalDocument {
  title: string;
  updated: string;
  sections: LegalSection[];
}

interface Props {
  doc: LegalDocument;
}

const { doc } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath("/", lang);

const description = doc.sections[0]?.paragraphs[0] ?? doc.title;
---

<BaseLayout title={`${doc.title} — Glottia`} description={description}>
  <article class="mx-auto max-w-3xl px-5 py-16 md:px-8 md:py-20">
    <a
      href={home}
      class="group inline-flex items-center gap-2 text-sm font-semibold text-accent transition-colors hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/50"
    >
      <Icon
        name="arrow"
        class="size-4 rotate-180 transition-transform group-hover:-translate-x-0.5"
      />
      {t.legal.backHome}
    </a>

    <header class="mt-6 border-b border-border pb-6">
      <h1
        class="text-balance text-3xl font-extrabold leading-[1.1] tracking-tight text-heading md:text-4xl"
      >
        {doc.title}
      </h1>
      <p class="mt-3 text-sm font-medium text-muted">
        {t.legal.updatedLabel}: {doc.updated}
      </p>
    </header>

    <div class="mt-10 space-y-10">
      {
        doc.sections.map((section) => (
          <section>
            <h2 class="text-xl font-bold tracking-tight text-heading md:text-2xl">
              {section.heading}
            </h2>
            <div class="mt-3 space-y-4 text-pretty leading-relaxed text-body md:text-lg/relaxed">
              {section.paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </article>
</BaseLayout>
