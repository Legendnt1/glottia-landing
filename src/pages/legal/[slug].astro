---
import LegalLayout from "../../layouts/LegalLayout.astro";
import { legalDocs, legalSlugs, useTranslations } from "../../utils/i18n";

// One statically-compiled page per legal document (English slugs).
export function getStaticPaths() {
  const t = useTranslations("en");
  return legalDocs.map((doc) => ({
    params: { slug: legalSlugs.en[doc] },
    props: { doc: t.legal[doc] },
  }));
}

const { doc } = Astro.props;
---

<LegalLayout doc={doc} />
