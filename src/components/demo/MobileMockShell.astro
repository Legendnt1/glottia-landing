---
// A pure HTML/CSS smartphone viewport simulation.
// Rounded bezel, deep inset shadow, camera notch. Content goes in the slot.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class={`relative mx-auto w-full max-w-95 ${className}`}>
  <!-- Glow behind the device -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 translate-y-8 scale-95 rounded-[3rem] bg-primary/20 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <!-- Device bezel -->
  <div
    class="relative rounded-[2.75rem] border border-white/10 bg-linear-to-b from-[#2a2a2a] to-[#0e0e0e] p-3 shadow-2xl shadow-black/60"
  >
    <!-- Screen -->
    <div
      class="relative aspect-9/19.5 overflow-hidden rounded-[2.1rem] bg-white shadow-[inset_0_0_0_1px_rgba(0,0,0,0.06)]"
    >
      <!-- Camera notch -->
      <div
        class="absolute left-1/2 top-2.5 z-30 flex h-7 w-28 -translate-x-1/2 items-center justify-center gap-2 rounded-full bg-black"
        aria-hidden="true"
      >
        <span class="size-2 rounded-full bg-white/15"></span>
        <span class="size-1.5 rounded-full bg-white/10"></span>
      </div>

      <!-- App content -->
      <div class="flex h-full flex-col">
        <slot />
      </div>
    </div>

    <!-- Side buttons -->
    <span
      class="absolute -left-1 top-24 h-12 w-1 rounded-l bg-[#0e0e0e]"
      aria-hidden="true"></span>
    <span
      class="absolute -right-1 top-32 h-16 w-1 rounded-r bg-[#0e0e0e]"
      aria-hidden="true"></span>
  </div>
</div>
