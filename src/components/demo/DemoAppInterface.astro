---
import { getLangFromUrl, useTranslations } from "../../utils/i18n";
import Icon from "../Icon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const d = t.demo;

const tabIcons = ["home", "calendar", "sparkles", "trophy"] as const;
---

<div
  id="glottia-demo"
  class="flex h-full flex-col bg-[#f6f7ee] text-neutral"
  data-active="0"
>
  <!-- Status bar -->
  <div
    class="flex items-center justify-between px-6 pb-1 pt-3 text-[11px] font-semibold text-neutral/60"
  >
    <span>9:41</span>
    <span class="h-2.5 w-5 rounded-sm border border-neutral/40 px-px">
      <span class="block h-full w-3/4 rounded-[1px] bg-secondary"></span>
    </span>
  </div>

  <!-- App top bar -->
  <div class="flex items-center gap-2 px-4 pb-2 pt-1">
    <span class="text-sm font-extrabold tracking-tight text-secondary">Glottia</span>
    <span
      data-screen-title
      class="ml-auto rounded-pill bg-white px-2.5 py-1 text-[11px] font-medium text-secondary shadow-sm"
      >{d.tabs[0]}</span
    >
  </div>

  <!-- Screen stage -->
  <div class="relative flex-1 overflow-hidden">
    <!-- ============ Screen 1 · Home ============ -->
    <section
      data-screen="0"
      class="absolute inset-0 overflow-y-auto px-4 pb-4 transition-all duration-300 ease-out"
      aria-label={d.tabs[0]}
    >
      <p class="text-lg font-extrabold">{d.s1.greeting}</p>
      <div class="mt-2 flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 rounded-pill border border-black/10 bg-white px-2.5 py-1 text-[11px] font-semibold">
          {d.s1.fluencyLabel}
          <span class="text-secondary">{d.s1.fluencyValue}</span>
        </span>
        <span class="inline-flex items-center gap-1 rounded-pill bg-neutral px-2.5 py-1 text-[11px] font-bold text-white">
          <span class="text-primary">★</span>
          {d.s1.points}
        </span>
      </div>

      <p class="mt-4 text-[10px] font-bold uppercase tracking-wider text-neutral/40">
        {d.s1.exploreLabel}
      </p>
      <div class="-mx-4 mt-2 flex gap-2 overflow-x-auto px-4 pb-1">
        {
          d.s1.langs.map((l, i) => (
            <span
              class:list={[
                "shrink-0 rounded-pill px-3 py-1.5 text-xs font-semibold",
                i === 0
                  ? "bg-primary text-neutral"
                  : "border border-black/10 bg-white text-neutral/60",
              ]}
            >
              {l}
            </span>
          ))
        }
      </div>

      <div class="mt-4 flex items-center justify-between">
        <p class="text-sm font-bold">{d.s1.upcomingTitle}</p>
        <span class="text-[11px] font-semibold text-secondary">{d.s1.seeAll}</span>
      </div>
      <div class="mt-2 space-y-2.5">
        {
          d.s1.meetups.map((meet) => (
            <button
              type="button"
              data-go={meet.full ? undefined : "1"}
              disabled={meet.full}
              class:list={[
                "animate-fade-in-up animate-duration-fast block w-full rounded-2xl border border-black/5 bg-white p-3.5 text-left shadow-[0_1px_2px_rgba(20,20,20,0.04)] transition-colors",
                meet.full ? "opacity-55" : "hover:border-secondary/40",
              ]}
            >
              <div class="flex items-center gap-2 text-[10px] font-semibold">
                <span class="rounded-pill bg-[#eef4cf] px-2 py-0.5 uppercase tracking-wide text-secondary">
                  {meet.level}
                </span>
                <span class="text-neutral/40">{meet.time}</span>
              </div>
              <div class="mt-1.5 flex items-center justify-between">
                <p class="text-sm font-bold">{meet.title}</p>
                <span
                  class:list={[
                    "text-[11px] font-semibold",
                    meet.full ? "text-red-500" : "text-secondary",
                  ]}
                >
                  {meet.seats}
                </span>
              </div>
            </button>
          ))
        }
      </div>
    </section>

    <!-- ============ Screen 2 · Meetup detail ============ -->
    <section
      data-screen="1"
      class="pointer-events-none absolute inset-0 translate-x-4 overflow-y-auto px-4 pb-4 opacity-0 transition-all duration-300 ease-out"
      aria-label={d.tabs[1]}
    >
      <div
        class="relative flex h-24 items-end overflow-hidden rounded-2xl bg-linear-to-br from-secondary to-primary p-4"
      >
        <Icon name="coffee" class="absolute right-3 top-3 size-9 text-neutral/30" />
        <div class="flex items-center gap-2">
          <span class="rounded-pill bg-white/90 px-2 py-0.5 text-[10px] font-bold text-neutral">
            {d.s2.levelBadge}
          </span>
          <span class="rounded-pill bg-neutral/85 px-2 py-0.5 text-[10px] font-bold text-primary">
            {d.s2.statusBadge}
          </span>
        </div>
      </div>

      <h2 class="mt-3 text-lg font-extrabold">{d.s2.title}</h2>
      <p class="mt-1 flex items-start gap-1.5 text-xs text-neutral/50">
        <Icon name="map-pin" class="mt-0.5 size-3.5 shrink-0 text-secondary" />
        <span><span class="font-semibold text-neutral/70">{d.s2.venue}</span> · {d.s2.address}</span>
      </p>

      <div class="mt-3 space-y-2">
        <div class="flex items-center gap-2.5 rounded-2xl border border-black/5 bg-white p-3">
          <Icon name="calendar" class="size-4 text-secondary" />
          <div>
            <p class="text-[10px] text-neutral/50">{d.s2.dateLabel}</p>
            <p class="text-xs font-semibold">{d.s2.date}</p>
          </div>
        </div>
        <div class="flex items-center gap-2.5 rounded-2xl border border-black/5 bg-white p-3">
          <Icon name="globe" class="size-4 text-secondary" />
          <div>
            <p class="text-[10px] text-neutral/50">{d.s2.langLabel}</p>
            <p class="text-xs font-semibold">{d.s2.lang}</p>
          </div>
        </div>
      </div>

      <div class="mt-3 rounded-2xl border border-black/5 bg-white p-3.5">
        <div class="flex items-center justify-between text-[11px]">
          <div class="flex -space-x-1.5">
            {
              ["#aadd00", "#7aa300", "#cdee5a"].map((c) => (
                <span class="size-6 rounded-full border-2 border-white" style={`background:${c}`} />
              ))
            }
          </div>
          <span class="font-semibold text-neutral/60">{d.s2.capacity}</span>
        </div>
        <div class="mt-2 h-1.5 overflow-hidden rounded-pill bg-[#eef4cf]">
          <div class="h-full rounded-pill bg-primary" style={`width:${d.s2.capacityPct}%`}></div>
        </div>
      </div>

      <p class="mt-4 text-xs font-bold text-neutral/70">{d.s2.aboutLabel}</p>
      <p class="mt-1.5 text-xs leading-relaxed text-neutral/55">{d.s2.about}</p>

      <button
        type="button"
        data-go="2"
        class="mt-5 flex w-full items-center justify-center gap-2 rounded-pill bg-primary py-3 text-sm font-semibold text-neutral transition-transform active:scale-[0.98]"
      >
        {d.s2.joinCta}
        <Icon name="arrow" class="size-4" />
      </button>
    </section>

    <!-- ============ Screen 3 · Quiz ============ -->
    <section
      data-screen="2"
      class="pointer-events-none absolute inset-0 translate-x-4 overflow-y-auto px-4 pb-4 opacity-0 transition-all duration-300 ease-out"
      aria-label={d.tabs[2]}
    >
      <div class="flex items-center justify-between">
        <span class="text-xs font-bold text-neutral/50">{d.s3.progress}</span>
        <span class="inline-flex items-center gap-1 rounded-pill bg-[#eef4cf] px-2 py-0.5 text-[10px] font-bold text-secondary">
          <span class="text-primary">★</span>
          {d.s3.reward}
        </span>
      </div>
      <div class="mt-2 h-1.5 overflow-hidden rounded-pill bg-[#eef4cf]">
        <div class="h-full w-3/5 rounded-pill bg-primary"></div>
      </div>

      <p class="mt-5 text-[11px] font-semibold uppercase tracking-wide text-neutral/40">
        {d.s3.instruction}
      </p>
      <h2 class="mt-1 text-lg font-extrabold leading-snug">{d.s3.question}</h2>

      <div class="mt-4 space-y-2.5">
        {
          d.s3.options.map((opt) => (
            <button
              type="button"
              data-option
              data-correct={String(opt.correct)}
              class="quiz-option flex w-full items-center justify-between rounded-2xl border border-black/10 bg-white px-4 py-3 text-left text-sm font-semibold transition-colors hover:border-secondary/50"
            >
              {opt.text}
              <span class="quiz-mark hidden" aria-hidden="true" />
            </button>
          ))
        }
      </div>

      <p
        data-quiz-correct
        class="mt-4 hidden items-center gap-2 rounded-2xl bg-[#eef4cf] px-4 py-3 text-sm font-bold text-secondary"
      >
        <Icon name="check" class="size-4" />
        {d.s3.correctMsg}
      </p>
      <p
        data-quiz-wrong
        class="mt-4 hidden items-center gap-2 rounded-2xl bg-red-50 px-4 py-3 text-sm font-semibold text-red-500"
      >
        {d.s3.wrongMsg}
      </p>

      <button
        type="button"
        data-go="3"
        data-quiz-next
        class="mt-4 hidden w-full items-center justify-center gap-2 rounded-pill bg-primary py-3 text-sm font-semibold text-neutral transition-transform active:scale-[0.98]"
      >
        {d.s3.nextCta}
        <Icon name="arrow" class="size-4" />
      </button>
    </section>

    <!-- ============ Screen 4 · Ranking ============ -->
    <section
      data-screen="3"
      class="pointer-events-none absolute inset-0 translate-x-4 overflow-y-auto px-4 pb-4 opacity-0 transition-all duration-300 ease-out"
      aria-label={d.tabs[3]}
    >
      <div class="flex items-center gap-2">
        <Icon name="trophy" class="size-5 text-secondary" />
        <h2 class="text-lg font-extrabold">{d.s4.title}</h2>
      </div>
      <p class="mt-0.5 text-xs text-neutral/50">{d.s4.endsIn}</p>

      <div class="mt-4 space-y-2">
        {
          d.s4.rows.map((row) => (
            <div
              class:list={[
                "flex items-center gap-3 rounded-2xl border p-3",
                row.you
                  ? "border-primary bg-[#f6fbe4] ring-1 ring-primary/40"
                  : "border-black/5 bg-white",
              ]}
            >
              <span class="w-4 text-center text-sm font-extrabold text-neutral/40">
                {row.rank}
              </span>
              <span class="flex size-9 items-center justify-center rounded-full bg-[#eef4cf] text-xs font-bold text-secondary">
                {row.name
                  .split(" ")
                  .map((w) => w[0])
                  .join("")}
              </span>
              <div class="min-w-0 flex-1">
                <p class="flex items-center gap-1.5 text-sm font-bold">
                  {row.name}
                  {row.you && (
                    <span class="rounded-pill bg-primary px-1.5 py-0.5 text-[9px] font-bold text-neutral">
                      {d.s4.youLabel}
                    </span>
                  )}
                </p>
                <p class="text-[11px] text-neutral/50">{row.tier}</p>
              </div>
              <span class="text-sm font-extrabold text-secondary">{row.pts}</span>
            </div>
          ))
        }
      </div>

      <p class="mt-4 flex items-center justify-center gap-1.5 text-xs font-semibold text-secondary">
        <span class="text-primary">★</span>
        {d.s4.footnote}
      </p>
    </section>
  </div>

  <!-- Bottom tab bar -->
  <nav
    class="flex items-center justify-around border-t border-black/5 bg-white/90 px-2 pb-3 pt-2 backdrop-blur"
    aria-label="Demo navigation"
  >
    {
      d.tabs.map((tab, i) => (
        <button
          type="button"
          data-tab={i}
          class:list={[
            "flex flex-1 flex-col items-center gap-1 rounded-xl py-1.5 text-[10px] font-medium transition-colors",
            i === 0 ? "text-secondary" : "text-neutral/40",
          ]}
          aria-current={i === 0 ? "page" : undefined}
        >
          <Icon name={tabIcons[i]} class="size-5" />
          {tab}
        </button>
      ))
    }
  </nav>
</div>

<script>
  const root = document.getElementById("glottia-demo");
  if (root) {
    const screens = Array.from(
      root.querySelectorAll<HTMLElement>("[data-screen]"),
    );
    const tabs = Array.from(root.querySelectorAll<HTMLElement>("[data-tab]"));
    const titleBadge = root.querySelector<HTMLElement>("[data-screen-title]");
    const tabLabels = tabs.map((t) => t.textContent?.trim() ?? "");

    function show(index: number) {
      screens.forEach((screen, i) => {
        const active = i === index;
        screen.classList.toggle("opacity-0", !active);
        screen.classList.toggle("translate-x-4", !active);
        screen.classList.toggle("pointer-events-none", !active);
        if (active) screen.scrollTop = 0;
      });
      tabs.forEach((tab, i) => {
        const active = i === index;
        tab.classList.toggle("text-secondary", active);
        tab.classList.toggle("text-neutral/40", !active);
        if (active) tab.setAttribute("aria-current", "page");
        else tab.removeAttribute("aria-current");
      });
      if (titleBadge) titleBadge.textContent = tabLabels[index] ?? "";
      root?.setAttribute("data-active", String(index));
      if (index === 2) resetQuiz();
    }

    tabs.forEach((tab, i) => tab.addEventListener("click", () => show(i)));

    root.querySelectorAll<HTMLElement>("[data-go]").forEach((el) => {
      el.addEventListener("click", () => {
        const target = Number(el.getAttribute("data-go"));
        if (!Number.isNaN(target)) show(target);
      });
    });

    // Quiz interaction
    const options = Array.from(
      root.querySelectorAll<HTMLElement>("[data-option]"),
    );
    const correctMsg = root.querySelector<HTMLElement>("[data-quiz-correct]");
    const wrongMsg = root.querySelector<HTMLElement>("[data-quiz-wrong]");
    const nextBtn = root.querySelector<HTMLElement>("[data-quiz-next]");

    function resetQuiz() {
      options.forEach((opt) => {
        opt.className =
          "quiz-option flex w-full items-center justify-between rounded-2xl border border-black/10 bg-white px-4 py-3 text-left text-sm font-semibold transition-colors hover:border-secondary/50";
        opt.removeAttribute("disabled");
        const mark = opt.querySelector(".quiz-mark");
        if (mark) mark.textContent = "";
      });
      correctMsg?.classList.add("hidden");
      correctMsg?.classList.remove("flex");
      wrongMsg?.classList.add("hidden");
      wrongMsg?.classList.remove("flex");
      nextBtn?.classList.add("hidden");
      nextBtn?.classList.remove("flex");
    }

    options.forEach((opt) => {
      opt.addEventListener("click", () => {
        const isCorrect = opt.getAttribute("data-correct") === "true";
        const mark = opt.querySelector(".quiz-mark");
        if (isCorrect) {
          opt.className =
            "quiz-option flex w-full items-center justify-between rounded-2xl border border-primary bg-[#eef4cf] px-4 py-3 text-left text-sm font-bold text-secondary";
          if (mark) mark.textContent = "✓";
          options.forEach((o) => o.setAttribute("disabled", "true"));
          wrongMsg?.classList.add("hidden");
          wrongMsg?.classList.remove("flex");
          correctMsg?.classList.remove("hidden");
          correctMsg?.classList.add("flex");
          nextBtn?.classList.remove("hidden");
          nextBtn?.classList.add("flex");
        } else {
          opt.className =
            "quiz-option flex w-full items-center justify-between rounded-2xl border border-red-300 bg-red-50 px-4 py-3 text-left text-sm font-semibold text-red-500";
          if (mark) mark.textContent = "✕";
          wrongMsg?.classList.remove("hidden");
          wrongMsg?.classList.add("flex");
        }
      });
    });

    // Deep links: /demo#meetup | #quiz | #ranking
    const hash = window.location.hash;
    if (hash === "#meetup") show(1);
    else if (hash === "#quiz") show(2);
    else if (hash === "#ranking") show(3);
  }
</script>
