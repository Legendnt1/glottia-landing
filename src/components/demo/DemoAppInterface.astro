---
import { getLangFromUrl, useTranslations } from "../../utils/i18n";
import MobileMockShell from "./MobileMockShell.astro";
import Icon from "../Icon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const d = t.demo;

const tabIcons = ["home", "calendar", "sparkles", "trophy"] as const;

// Absolutely-stacked app screens; only the active one is shown (others get the
// `hidden` attribute). Showing one plays a lightweight fade via global.css.
const screen = "app-screen absolute inset-0 overflow-y-auto px-4 pb-4";
---

<section id="glottia-demo" class="px-5 py-12 md:px-8 md:py-16">
  <div
    class="mx-auto grid w-full max-w-6xl items-center gap-8 lg:grid-cols-2 lg:gap-16"
  >
    <!-- LEFT · step list (desktop tablist) -->
    <ol
      role="tablist"
      aria-label={d.title}
      aria-orientation="vertical"
      class="order-2 hidden lg:order-1 lg:block"
    >
      {
        d.steps.map((step, i) => (
          <li role="presentation">
            <button
              type="button"
              data-jump={i}
              role="tab"
              id={`demo-steptab-${i}`}
              aria-controls={`demo-panel-${i}`}
              aria-selected={i === 0 ? "true" : "false"}
              class="flex w-full items-start gap-4 rounded-2xl py-4 text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/50"
            >
              <span
                data-bullet={i}
                class:list={[
                  "flex size-9 shrink-0 items-center justify-center rounded-full border text-sm font-bold transition-colors",
                  i === 0
                    ? "border-primary bg-primary text-neutral"
                    : "border-border text-muted",
                ]}
              >
                {i + 1}
              </span>
              <div
                data-step-text={i}
                class:list={[
                  "transition-opacity duration-300",
                  i === 0 ? "opacity-100" : "opacity-40",
                ]}
              >
                <p class="font-bold text-heading md:text-lg">{step.title}</p>
                <p class="mt-1 text-sm text-body">{step.desc}</p>
              </div>
            </button>
          </li>
        ))
      }
    </ol>

    <!-- RIGHT · phone -->
    <div class="order-1 mx-auto w-full max-w-90 lg:order-2 lg:w-90">
      <MobileMockShell>
        <div class="flex h-full flex-col bg-cream text-neutral">
          <!-- Status bar -->
          <div
            class="flex items-center justify-between px-6 pb-1 pt-3 text-[11px] font-semibold text-neutral/60"
          >
            <span>9:41</span>
            <span class="h-2.5 w-5 rounded-sm border border-neutral/40 px-px">
              <span class="block h-full w-3/4 rounded-[1px] bg-secondary"></span>
            </span>
          </div>

          <!-- App top bar -->
          <div class="flex items-center gap-2 px-4 pb-2 pt-1">
            <span class="text-sm font-extrabold tracking-tight text-secondary"
              >Glottia</span
            >
            <span
              data-screen-title
              class="ml-auto rounded-pill bg-white px-2.5 py-1 text-[11px] font-medium text-secondary shadow-sm"
              >{d.tabs[0]}</span
            >
          </div>

          <!-- Screen stage (4 absolutely-stacked, toggled screens) -->
          <div class="relative flex-1 overflow-hidden">
            <!-- Screen 1 · Home -->
            <div
              class={screen}
              id="demo-panel-0"
              role="tabpanel"
              aria-labelledby="demo-tab-0"
              data-panel="0"
            >
              <p class="text-lg font-extrabold">{d.s1.greeting}</p>
              <div class="mt-2 flex items-center gap-2">
                <span class="inline-flex items-center gap-1.5 rounded-pill border border-black/10 bg-white px-2.5 py-1 text-[11px] font-semibold">
                  {d.s1.fluencyLabel}
                  <span class="text-secondary">{d.s1.fluencyValue}</span>
                </span>
                <span class="inline-flex items-center gap-1 rounded-pill bg-neutral px-2.5 py-1 text-[11px] font-bold text-white">
                  <span class="text-primary">★</span>
                  {d.s1.points}
                </span>
              </div>

              <p class="mt-4 text-[10px] font-bold uppercase tracking-wider text-neutral/40">
                {d.s1.exploreLabel}
              </p>
              <div class="-mx-4 mt-2 flex gap-2 overflow-x-auto px-4 pb-1">
                {
                  d.s1.langs.map((l, i) => (
                    <span
                      class:list={[
                        "shrink-0 rounded-pill px-3 py-1.5 text-xs font-semibold",
                        i === 0
                          ? "bg-primary text-neutral"
                          : "border border-black/10 bg-white text-neutral/60",
                      ]}
                    >
                      {l}
                    </span>
                  ))
                }
              </div>

              <div class="mt-4 flex items-center justify-between">
                <p class="text-sm font-bold">{d.s1.upcomingTitle}</p>
                <span class="text-[11px] font-semibold text-secondary"
                  >{d.s1.seeAll}</span
                >
              </div>
              <div class="mt-2 space-y-2.5">
                {
                  d.s1.meetups.map((meet) => (
                    <button
                      type="button"
                      data-jump={meet.full ? undefined : "1"}
                      disabled={meet.full}
                      class:list={[
                        "block w-full rounded-2xl border border-black/5 bg-white p-3.5 text-left shadow-card-xs transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50",
                        meet.full ? "opacity-55" : "hover:border-secondary/40",
                      ]}
                    >
                      <div class="flex items-center gap-2 text-[10px] font-semibold">
                        <span class="rounded-pill bg-lime-soft px-2 py-0.5 uppercase tracking-wide text-secondary">
                          {meet.level}
                        </span>
                        <span class="text-neutral/40">{meet.time}</span>
                      </div>
                      <div class="mt-1.5 flex items-center justify-between">
                        <p class="text-sm font-bold">{meet.title}</p>
                        <span
                          class:list={[
                            "text-[11px] font-semibold",
                            meet.full ? "text-red-500" : "text-secondary",
                          ]}
                        >
                          {meet.seats}
                        </span>
                      </div>
                    </button>
                  ))
                }
              </div>
            </div>

            <!-- Screen 2 · Meetup detail -->
            <div
              class={screen}
              id="demo-panel-1"
              role="tabpanel"
              aria-labelledby="demo-tab-1"
              data-panel="1"
              hidden
            >
              <div
                class="relative flex h-24 items-end overflow-hidden rounded-2xl bg-linear-to-br from-secondary to-primary p-4"
              >
                <Icon
                  name="coffee"
                  class="absolute right-3 top-3 size-9 text-neutral/30"
                />
                <div class="flex items-center gap-2">
                  <span class="rounded-pill bg-white/90 px-2 py-0.5 text-[10px] font-bold text-neutral">
                    {d.s2.levelBadge}
                  </span>
                  <span class="rounded-pill bg-neutral/85 px-2 py-0.5 text-[10px] font-bold text-primary">
                    {d.s2.statusBadge}
                  </span>
                </div>
              </div>

              <h2 class="mt-3 text-lg font-extrabold">{d.s2.title}</h2>
              <p class="mt-1 flex items-start gap-1.5 text-xs text-neutral/50">
                <Icon
                  name="map-pin"
                  class="mt-0.5 size-3.5 shrink-0 text-secondary"
                />
                <span
                  ><span class="font-semibold text-neutral/70">{d.s2.venue}</span
                  > · {d.s2.address}</span
                >
              </p>

              <div class="mt-3 space-y-2">
                <div class="flex items-center gap-2.5 rounded-2xl border border-black/5 bg-white p-3">
                  <Icon name="calendar" class="size-4 text-secondary" />
                  <div>
                    <p class="text-[10px] text-neutral/50">{d.s2.dateLabel}</p>
                    <p class="text-xs font-semibold">{d.s2.date}</p>
                  </div>
                </div>
                <div class="flex items-center gap-2.5 rounded-2xl border border-black/5 bg-white p-3">
                  <Icon name="globe" class="size-4 text-secondary" />
                  <div>
                    <p class="text-[10px] text-neutral/50">{d.s2.langLabel}</p>
                    <p class="text-xs font-semibold">{d.s2.lang}</p>
                  </div>
                </div>
              </div>

              <div class="mt-3 rounded-2xl border border-black/5 bg-white p-3.5">
                <div class="flex items-center justify-between text-[11px]">
                  <div class="flex -space-x-1.5">
                    {
                      ["#aadd00", "#7aa300", "#cdee5a"].map((c) => (
                        <span
                          class="size-6 rounded-full border-2 border-white"
                          style={`background:${c}`}
                        />
                      ))
                    }
                  </div>
                  <span class="font-semibold text-neutral/60">{d.s2.capacity}</span>
                </div>
                <div class="mt-2 h-1.5 overflow-hidden rounded-pill bg-lime-soft">
                  <div
                    class="h-full rounded-pill bg-primary"
                    style={`width:${d.s2.capacityPct}%`}
                  >
                  </div>
                </div>
              </div>

              <p class="mt-4 text-xs font-bold text-neutral/70">{d.s2.aboutLabel}</p>
              <p class="mt-1.5 text-xs leading-relaxed text-neutral/55">
                {d.s2.about}
              </p>

              <button
                type="button"
                data-jump="2"
                class="mt-5 flex w-full items-center justify-center gap-2 rounded-pill bg-primary py-3 text-sm font-semibold text-neutral transition-transform active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50"
              >
                {d.s2.joinCta}
                <Icon name="arrow" class="size-4" />
              </button>
            </div>

            <!-- Screen 3 · Quiz -->
            <div
              class={screen}
              id="demo-panel-2"
              role="tabpanel"
              aria-labelledby="demo-tab-2"
              data-panel="2"
              hidden
            >
              <div class="flex items-center justify-between">
                <span class="text-xs font-bold text-neutral/50">{d.s3.progress}</span>
                <span class="inline-flex items-center gap-1 rounded-pill bg-lime-soft px-2 py-0.5 text-[10px] font-bold text-secondary">
                  <span class="text-primary">★</span>
                  {d.s3.reward}
                </span>
              </div>
              <div class="mt-2 h-1.5 overflow-hidden rounded-pill bg-lime-soft">
                <div class="h-full w-3/5 rounded-pill bg-primary"></div>
              </div>

              <p class="mt-5 text-[11px] font-semibold uppercase tracking-wide text-neutral/40">
                {d.s3.instruction}
              </p>
              <h2 class="mt-1 text-lg font-extrabold leading-snug">
                {d.s3.question}
              </h2>

              <div class="mt-4 space-y-2.5">
                {
                  d.s3.options.map((opt) => (
                    <button
                      type="button"
                      data-option
                      data-correct={String(opt.correct)}
                      class="quiz-option flex w-full items-center justify-between rounded-2xl border border-black/10 bg-white px-4 py-3 text-left text-sm font-semibold transition-colors hover:border-secondary/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50"
                    >
                      {opt.text}
                    </button>
                  ))
                }
              </div>

              <p
                data-quiz-correct
                class="mt-4 hidden items-center gap-2 rounded-2xl bg-lime-soft px-4 py-3 text-sm font-bold text-secondary"
              >
                <Icon name="check" class="size-4" />
                {d.s3.correctMsg}
              </p>
              <p
                data-quiz-wrong
                class="mt-4 hidden items-center gap-2 rounded-2xl bg-red-50 px-4 py-3 text-sm font-semibold text-red-500"
              >
                {d.s3.wrongMsg}
              </p>

              <button
                type="button"
                data-jump="3"
                data-quiz-next
                class="mt-4 hidden w-full items-center justify-center gap-2 rounded-pill bg-primary py-3 text-sm font-semibold text-neutral focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50"
              >
                {d.s3.nextCta}
                <Icon name="arrow" class="size-4" />
              </button>
            </div>

            <!-- Screen 4 · Ranking -->
            <div
              class={screen}
              id="demo-panel-3"
              role="tabpanel"
              aria-labelledby="demo-tab-3"
              data-panel="3"
              hidden
            >
              <div class="flex items-center gap-2">
                <Icon name="trophy" class="size-5 text-secondary" />
                <h2 class="text-lg font-extrabold">{d.s4.title}</h2>
              </div>
              <p class="mt-0.5 text-xs text-neutral/50">{d.s4.endsIn}</p>

              <div class="mt-4 space-y-2">
                {
                  d.s4.rows.map((row) => (
                    <div
                      class:list={[
                        "flex items-center gap-3 rounded-2xl border p-3",
                        row.you
                          ? "border-primary bg-[#f6fbe4] ring-1 ring-primary/40"
                          : "border-black/5 bg-white",
                      ]}
                    >
                      <span class="w-4 text-center text-sm font-extrabold text-neutral/40">
                        {row.rank}
                      </span>
                      <span class="flex size-9 items-center justify-center rounded-full bg-lime-soft text-xs font-bold text-secondary">
                        {row.name
                          .split(" ")
                          .map((w) => w[0])
                          .join("")}
                      </span>
                      <div class="min-w-0 flex-1">
                        <p class="flex items-center gap-1.5 text-sm font-bold">
                          {row.name}
                          {row.you && (
                            <span class="rounded-pill bg-primary px-1.5 py-0.5 text-[9px] font-bold text-neutral">
                              {d.s4.youLabel}
                            </span>
                          )}
                        </p>
                        <p class="text-[11px] text-neutral/50">{row.tier}</p>
                      </div>
                      <span class="text-sm font-extrabold text-secondary">
                        {row.pts}
                      </span>
                    </div>
                  ))
                }
              </div>

              <p class="mt-4 flex items-center justify-center gap-1.5 text-xs font-semibold text-secondary">
                <span class="text-primary">★</span>
                {d.s4.footnote}
              </p>
            </div>
          </div>

          <!-- Bottom tab bar -->
          <nav
            class="flex items-center justify-around border-t border-black/5 bg-white/90 px-2 pb-3 pt-2 backdrop-blur"
            aria-label="Demo navigation"
            role="tablist"
          >
            {
              d.tabs.map((tab, i) => (
                <button
                  type="button"
                  data-jump={i}
                  data-tab={i}
                  role="tab"
                  id={`demo-tab-${i}`}
                  aria-controls={`demo-panel-${i}`}
                  aria-selected={i === 0 ? "true" : "false"}
                  class:list={[
                    "flex flex-1 flex-col items-center gap-1 rounded-xl py-1.5 text-[10px] font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50",
                    i === 0 ? "text-secondary" : "text-neutral/40",
                  ]}
                >
                  <Icon name={tabIcons[i]} class="size-5" />
                  {tab}
                </button>
              ))
            }
          </nav>
        </div>
      </MobileMockShell>
    </div>

    <!-- Mobile caption -->
    <div class="order-3 mx-auto w-full max-w-sm text-center lg:hidden">
      <p id="m-step-title" class="text-base font-extrabold text-heading">
        {d.steps[0].title}
      </p>
      <div class="mt-2 flex justify-center gap-2" aria-hidden="true">
        {
          d.steps.map((_, i) => (
            <span
              data-dot={i}
              class:list={[
                "h-1.5 rounded-pill transition-all duration-300",
                i === 0 ? "w-6 bg-primary" : "w-1.5 bg-border",
              ]}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.getElementById("glottia-demo");
  if (root) {
    const panels = Array.from(
      root.querySelectorAll<HTMLElement>("[data-panel]"),
    );
    const allTabs = Array.from(
      root.querySelectorAll<HTMLElement>('[role="tab"]'),
    );
    const bullets = Array.from(root.querySelectorAll<HTMLElement>("[data-bullet]"));
    const stepTexts = Array.from(
      root.querySelectorAll<HTMLElement>("[data-step-text]"),
    );
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const navTabs = Array.from(root.querySelectorAll<HTMLElement>("[data-tab]"));
    const titleBadge = root.querySelector<HTMLElement>("[data-screen-title]");
    const mTitle = root.querySelector<HTMLElement>("#m-step-title");
    const tabLabels = navTabs.map((t) => t.textContent?.trim() ?? "");
    const stepTitles = stepTexts.map(
      (s) => s.querySelector("p")?.textContent ?? "",
    );

    let current = -1;
    function setActive(i: number) {
      if (i === current || i < 0 || i >= panels.length) return;
      current = i;

      // Instant screen toggle (only the active panel stays in the a11y tree).
      panels.forEach((p, idx) => {
        p.hidden = idx !== i;
      });
      allTabs.forEach((tb) => {
        tb.setAttribute(
          "aria-selected",
          String(Number(tb.dataset.jump) === i),
        );
      });

      bullets.forEach((b, idx) => {
        const on = idx === i;
        b.classList.toggle("border-primary", on);
        b.classList.toggle("bg-primary", on);
        b.classList.toggle("text-neutral", on);
        b.classList.toggle("border-border", !on);
        b.classList.toggle("text-muted", !on);
      });
      stepTexts.forEach((s, idx) => {
        s.classList.toggle("opacity-100", idx === i);
        s.classList.toggle("opacity-40", idx !== i);
      });
      dots.forEach((dt, idx) => {
        const on = idx === i;
        dt.classList.toggle("w-6", on);
        dt.classList.toggle("bg-primary", on);
        dt.classList.toggle("w-1.5", !on);
        dt.classList.toggle("bg-border", !on);
      });
      navTabs.forEach((tb, idx) => {
        const on = idx === i;
        tb.classList.toggle("text-secondary", on);
        tb.classList.toggle("text-neutral/40", !on);
      });
      if (titleBadge) titleBadge.textContent = tabLabels[i] ?? "";
      if (mTitle) mTitle.textContent = stepTitles[i] ?? "";
    }

    // Tab / nav / in-screen CTA → switch screen instantly (no scrolling).
    root.querySelectorAll<HTMLElement>("[data-jump]").forEach((el) => {
      el.addEventListener("click", () => {
        const i = Number(el.getAttribute("data-jump"));
        if (Number.isNaN(i)) return;
        setActive(i);
      });
    });

    // Quiz interactivity (independent of the active screen).
    const options = Array.from(
      root.querySelectorAll<HTMLElement>("[data-option]"),
    );
    const correctMsg = root.querySelector<HTMLElement>("[data-quiz-correct]");
    const wrongMsg = root.querySelector<HTMLElement>("[data-quiz-wrong]");
    const nextBtn = root.querySelector<HTMLElement>("[data-quiz-next]");
    options.forEach((opt) => {
      opt.addEventListener("click", () => {
        const ok = opt.getAttribute("data-correct") === "true";
        if (ok) {
          opt.className =
            "quiz-option flex w-full items-center justify-between rounded-2xl border border-primary bg-lime-soft px-4 py-3 text-left text-sm font-bold text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50";
          options.forEach((o) => o.setAttribute("disabled", "true"));
          wrongMsg?.classList.add("hidden");
          wrongMsg?.classList.remove("flex");
          correctMsg?.classList.remove("hidden");
          correctMsg?.classList.add("flex");
          nextBtn?.classList.remove("hidden");
          nextBtn?.classList.add("flex");
        } else {
          opt.className =
            "quiz-option flex w-full items-center justify-between rounded-2xl border border-red-300 bg-red-50 px-4 py-3 text-left text-sm font-semibold text-red-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/50";
          wrongMsg?.classList.remove("hidden");
          wrongMsg?.classList.add("flex");
        }
      });
    });

    setActive(0);
  }
</script>
