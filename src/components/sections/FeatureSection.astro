---
import { getLangFromUrl, useTranslations, localizePath } from "../../utils/i18n";
import Icon from "../Icon.astro";
import MeetupMockup from "../mockups/MeetupMockup.astro";
import ProgressMockup from "../mockups/ProgressMockup.astro";

interface Props {
  index: number;
}

const { index } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const f = t.features[index];

const demoHref = localizePath("/demo", lang);
const linkHref = f.mockup === "progress" ? `${demoHref}#quiz` : demoHref;
---

<section id={f.id} class="scroll-mt-24 px-5 py-12 md:px-8 md:py-16">
  <div
    class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16"
  >
    <!-- Copy -->
    <div
      class:list={[
        "order-2",
        f.reverse ? "lg:order-2" : "lg:order-1",
      ]}
    >
      <span
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-accent"
      >
        <span class="size-2 rounded-full bg-primary"></span>
        {f.eyebrow}
      </span>
      <h2
        class="view-animate-fade-in-up animate-duration-slow mt-4 text-balance text-3xl font-extrabold leading-[1.1] tracking-tight text-heading md:text-4xl"
      >
        {f.title}
      </h2>
      <p
        class="view-animate-fade-in-up animate-delay-150 animate-duration-slow mt-4 max-w-md text-pretty text-base text-body md:text-lg"
      >
        {f.body}
      </p>

      <ul class="mt-7 space-y-4">
        {
          f.bullets.map((bullet) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-accent-soft text-accent">
                <Icon name="check" class="size-3.5" />
              </span>
              <span class="text-sm text-body md:text-base">{bullet}</span>
            </li>
          ))
        }
      </ul>

      <a
        href={linkHref}
        class="group mt-8 inline-flex items-center gap-2 text-sm font-bold text-accent transition-colors hover:text-secondary"
      >
        {f.linkLabel}
        <Icon
          name="arrow"
          class="size-4 transition-transform group-hover:translate-x-1"
        />
      </a>
    </div>

    <!-- Mockup -->
    <div
      class:list={[
        "order-1",
        f.reverse ? "lg:order-1" : "lg:order-2",
      ]}
    >
      {f.mockup === "meetup" && <MeetupMockup />}
      {f.mockup === "progress" && <ProgressMockup />}
    </div>
  </div>
</section>
