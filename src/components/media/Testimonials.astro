---
import { getLangFromUrl, useTranslations } from "../../utils/i18n";
import Icon from "../Icon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tm = t.media.testimonials;

const initials = (name: string) =>
  name
    .split(" ")
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase() ?? "")
    .join("");
---

<section id="testimonials" class="scroll-mt-24 px-5 py-16 md:px-8 md:py-20">
  <div class="mx-auto max-w-2xl text-center">
    <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent">
      {tm.eyebrow}
    </span>
    <h2
      class="view-animate-fade-in-up animate-duration-slow mt-4 text-balance text-3xl font-extrabold leading-[1.1] tracking-tight text-gradient-brand md:text-4xl"
    >
      {tm.title}
    </h2>
    <p
      class="view-animate-fade-in-up animate-delay-150 animate-duration-slow mx-auto mt-4 max-w-xl text-pretty text-base text-body md:text-lg"
    >
      {tm.subtitle}
    </p>
  </div>

  <div class="mx-auto mt-12 grid max-w-5xl gap-5 md:grid-cols-2">
    {
      tm.items.map((item) => {
        const isLearner = item.kind === "learner";
        return (
          <figure class="view-animate-fade-in-up animate-duration-slow relative flex flex-col rounded-card border border-border bg-surface p-6 shadow-sm transition-colors hover:border-accent/40 hover:bg-elevated md:p-7">
            <div class="flex items-start justify-between gap-3">
              <Icon name="chat" class="size-7 text-border" />
              <span
                class:list={[
                  "rounded-pill px-2.5 py-1 text-[11px] font-bold",
                  isLearner
                    ? "bg-accent-soft text-accent"
                    : "border border-border text-muted",
                ]}
              >
                {isLearner ? tm.chips.learner : tm.chips.partner}
              </span>
            </div>

            <div
              class="mt-3 flex items-center gap-0.5 text-amber"
              role="img"
              aria-label={`${item.rating} / 5`}
            >
              {Array.from({ length: item.rating }).map(() => (
                <Icon name="star" class="size-4" />
              ))}
            </div>

            <blockquote class="mt-3 grow text-pretty text-sm leading-relaxed text-body md:text-base">
              {item.quote}
            </blockquote>

            <figcaption class="mt-5 flex items-center gap-3">
              <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-accent-soft text-xs font-bold text-accent">
                {initials(item.name)}
              </span>
              <span>
                <span class="block text-sm font-bold text-heading">
                  {item.name}
                </span>
                <span class="block text-xs text-muted">{item.role}</span>
              </span>
            </figcaption>
          </figure>
        );
      })
    }
  </div>
</section>
